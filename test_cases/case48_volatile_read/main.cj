// case48: volatileеҸҳйҮҸжөӢиҜ•
// жөӢиҜ•volatileе…ій”®еӯ—зҡ„дҪҝз”Ё

main() {
    @Volatile
    var flag: Bool = false
    var data: Int64 = 0
    
    spawn {
        data = 100
        flag = true  // volatileеҶҷ
    }
    
    spawn {
        while (!flag) {  // volatileиҜ»
            // зӯүеҫ…
        }
        let value = data  // иҜ»еҸ–data
    }
}